<Window x:Class="RecruitmentOcrApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arknights Recruitment OCR" Height="640" Width="420"
        Topmost="True">
    <StackPanel Margin="12">
        <TextBlock Text="Capture region (screen pixels)" FontWeight="Bold" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="X:" VerticalAlignment="Center"/>
            <TextBox x:Name="RegionX" Width="50" Margin="4,0" Text="0"/>
            <TextBlock Text="Y:" VerticalAlignment="Center"/>
            <TextBox x:Name="RegionY" Width="50" Margin="4,0" Text="0"/>
            <TextBlock Text="W:" VerticalAlignment="Center"/>
            <TextBox x:Name="RegionWidth" Width="50" Margin="4,0" Text="800"/>
            <TextBlock Text="H:" VerticalAlignment="Center"/>
            <TextBox x:Name="RegionHeight" Width="50" Margin="4,0" Text="80"/>
        </StackPanel>

        <Button x:Name="CaptureButton" Content="Capture Tags" Click="OnCaptureClicked" Margin="0,0,0,12"/>

        <TextBlock x:Name="StatusText" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <TextBlock Text="Detected tags (uncheck any misreads)" FontWeight="Bold" Margin="0,0,0,4"/>
        <StackPanel x:Name="DetectedTagsPanel" Margin="0,0,0,12"/>

        <Button x:Name="RecalculateButton" Content="Recalculate" Click="OnRecalculateClicked" Margin="0,0,0,12"/>

        <TextBlock Text="Results" FontWeight="Bold" Margin="0,0,0,4"/>
        <ListBox x:Name="ResultsList" Height="220"/>
    </StackPanel>
</Window>
