<Window x:Class="RecruitmentOcrApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arknights Recruitment OCR" Height="640" Width="420"
        Topmost="True">
    <StackPanel Margin="12">
        <Button x:Name="SelectWindowButton" Content="Select Emulator Window" Click="OnSelectWindowClicked" Margin="0,0,0,8"/>
        <TextBlock x:Name="WindowStatusText" Text="No window selected yet." Margin="0,0,0,8" TextWrapping="Wrap"/>

        <Button x:Name="CaptureButton" Content="Capture Tags" Click="OnCaptureClicked" Margin="0,0,0,12" IsEnabled="False"/>

        <TextBlock x:Name="StatusText" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <TextBlock Text="Detected tags (uncheck any misreads)" FontWeight="Bold" Margin="0,0,0,4"/>
        <StackPanel x:Name="DetectedTagsPanel" Margin="0,0,0,12"/>

        <Button x:Name="RecalculateButton" Content="Recalculate" Click="OnRecalculateClicked" Margin="0,0,0,12"/>

        <TextBlock Text="Results" FontWeight="Bold" Margin="0,0,0,4"/>
        <ListBox x:Name="ResultsList" Height="220"/>
    </StackPanel>
</Window>
