<Window x:Class="RecruitmentOcrApp.TagRegionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drag a box over the tag row"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Margin="8"
                    Text="Click and drag a rectangle over the recruitment tag text, then click Confirm."/>
        <Button x:Name="ConfirmButton" DockPanel.Dock="Bottom" Content="Confirm" Margin="8"
                IsEnabled="False" Click="OnConfirmClicked"/>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      MaxWidth="1200" MaxHeight="800">
            <Grid>
                <Image x:Name="PreviewImage" Stretch="None"/>
                <Canvas x:Name="SelectionCanvas" Background="Transparent"
                        MouseLeftButtonDown="OnCanvasMouseDown"
                        MouseMove="OnCanvasMouseMove"
                        MouseLeftButtonUp="OnCanvasMouseUp">
                    <Rectangle x:Name="SelectionRectangle" Stroke="Red" StrokeThickness="2" Visibility="Collapsed"/>
                </Canvas>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
